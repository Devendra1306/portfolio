# =========================================================================
# PORTFOLIO BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to '.env' in the same directory and fill in your details.
# DO NOT commit your real '.env' file with passwords to Git.
# =========================================================================

# --- Server Configurations ---
PORT=3000
NODE_ENV=development

# --- SMTP Email Notifications (Optional) ---
# If configured, the backend will email you when someone submits the contact form.
# If left blank, the server will log submissions to the SQLite database without emailing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True

# Your SMTP account credentials (e.g., your Gmail address and Gmail App Password)
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_secure_app_password

# The destination email address where you want to receive contact alerts
CONTACT_RECEIVER=devendrasagar0988@gmail.com
